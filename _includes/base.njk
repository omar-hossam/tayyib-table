<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/css/style.css">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
</head>
<body x-data="{ sidebar: false }">
  <header class="bg-[var(--nav)] fixed top-0 left-0 w-screen z-80 shadow-md">
    <nav class="flex items-center justify-between px-2 py-1">
      <ul class="flex gap-5">
        <li><a href="/"><img src="/images/logo.png" alt="Tayyib Table" class="w-15 sm:w-20" /></a></li>

        <ul class="hidden sm:flex items-center gap-8">
          {% include '_components/reuse/nav-links.njk' %}
        </ul>
      </ul>
      <ul class="flex items-center gap-2 sm:gap-3">
        <li class="hidden sm:block">
          <button class="border flex gap-1 items-center border-2 border-[#236730] px-3 py-2 rounded-lg font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#236730]" viewBox="0 0 256 256"><rect  fill="none"/><path d="M188,184H91.17a16,16,0,0,1-15.74-13.14L48.73,24H24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><circle cx="92" cy="204" r="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><circle cx="188" cy="204" r="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M70.55,144H196.1a16,16,0,0,0,15.74-13.14L224,64H56" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
            Cart (2)
          </button>
        </li>
        <li class="hidden sm:block">
          <button class="border border-2 rounded-lg font-bold py-2 px-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 256 256"><rect fill="none"/><path d="M108.11,28.11A96.09,96.09,0,0,0,227.89,147.89,96,96,0,1,1,108.11,28.11Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
          </button>
        </li>
        
        <!-- PHONE -->
        <li class="sm:hidden"><a href="/cart">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#236730]" viewBox="0 0 256 256"><rect  fill="none"/><path d="M188,184H91.17a16,16,0,0,1-15.74-13.14L48.73,24H24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><circle cx="92" cy="204" r="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><circle cx="188" cy="204" r="20" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><path d="M70.55,144H196.1a16,16,0,0,0,15.74-13.14L224,64H56" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
        </a></li>
        
        <li class="flex justify-center items-center sm:hidden">
          <button class="p-1" @click="sidebar = true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#236730]" viewBox="0 0 256 256"><rect fill="none"/><line x1="40" y1="128" x2="216" y2="128" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="40" y1="64" x2="216" y2="64" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="40" y1="192" x2="216" y2="192" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
          </button>
        </li>
      </ul>
    </nav>
  </header>
  <aside x-show="sidebar === true" class="fixed top-0 left-0 w-screen h-screen bg-[#fbf5eeee] sm:hidden" x-transition>
    <button @click="sidebar = false" class="absolute top-4 right-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-black" viewBox="0 0 256 256"><rect fill="none"/><line x1="200" y1="56" x2="56" y2="200" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/><line x1="200" y1="200" x2="56" y2="56" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
    </button>
    <ul class="flex flex-col gap-8 w-full pt-15 items-center">
      {% include '_components/reuse/nav-links.njk' %}
    
      <li>
          <button class="border border-2 rounded-lg font-bold py-2 px-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 256 256"><rect fill="none"/><path d="M108.11,28.11A96.09,96.09,0,0,0,227.89,147.89,96,96,0,1,1,108.11,28.11Z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="16"/></svg>
          </button>
        </li>
      
      
    </ul>
  </aside>
  
  {{ content | safe }}
  
  
  <script src="/js/main.js" type="module"></script>
</body>
</html>
